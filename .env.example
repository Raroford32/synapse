# ===================================
# Synapse Configuration
# ===================================
# Copy this file to .env and update with your values

# Environment (development, staging, production)
ENVIRONMENT=development

# ===================================
# Security
# ===================================
# Generate strong secrets for production!
# You can generate these with: openssl rand -hex 32
API_KEY=your-synapse-api-key-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production

# ===================================
# Database Configuration
# ===================================
# PostgreSQL with pgvector extension
DATABASE_URL=postgresql://synapse:synapse_password@localhost:5432/synapse_db

# Redis for caching (optional but recommended)
REDIS_URL=redis://localhost:6379

# ===================================
# LLM Provider API Keys
# ===================================
# Add only the providers you want to use
# At least one provider is recommended

# OpenAI (GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=sk-...

# Anthropic (Claude 3.5 Sonnet, etc.)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini Pro, etc.)
GOOGLE_API_KEY=...

# Mistral AI
MISTRAL_API_KEY=...

# Cohere
COHERE_API_KEY=...

# Replicate (for open source models)
REPLICATE_API_TOKEN=...

# HuggingFace
HUGGINGFACE_API_KEY=...

# OpenRouter (access to multiple models)
OPENROUTER_API_KEY=...

# Groq (fast inference)
GROQ_API_KEY=...

# Together AI
TOGETHER_API_KEY=...

# ===================================
# Local Model Configuration
# ===================================
# Ollama for local models (optional)
OLLAMA_HOST=http://localhost:11434

# ===================================
# Memory System Configuration
# ===================================
# Mem0 configuration
MEM0_CONFIG_PATH=/app/config/mem0.yaml
MEM0_VECTOR_STORE=pgvector
MEM0_EMBEDDING_MODEL=text-embedding-3-small

# ===================================
# RAG System Configuration  
# ===================================
# R2R configuration
R2R_CONFIG_PATH=/app/config/r2r.yaml
R2R_VECTOR_DIMENSION=1536
R2R_CHUNK_SIZE=512
R2R_CHUNK_OVERLAP=50

# ===================================
# MCP (Model Context Protocol)
# ===================================
# MCP server configuration
MCP_ENABLED=true
MCP_SERVER_PORT=8001

# ===================================
# CORS Settings
# ===================================
# Comma-separated list of allowed origins
# Use * for all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,*

# ===================================
# Logging
# ===================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===================================
# Optional Services
# ===================================
# Sentry for error tracking (optional)
SENTRY_DSN=

# Prometheus metrics (optional)
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=9090

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===================================
# Model Routing Configuration
# ===================================
# Default model selection strategy
MODEL_SELECTION_STRATEGY=auto  # auto, manual, cost-optimized, performance
DEFAULT_MODEL=gpt-4o-mini
SMART_MODEL=claude-3-5-sonnet-20241022
FAST_MODEL=gpt-4o-mini

# ===================================
# WebSocket Configuration
# ===================================
WS_HEARTBEAT_INTERVAL=30
WS_CONNECTION_TIMEOUT=600

# ===================================
# File Upload Configuration
# ===================================
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_EXTENSIONS=pdf,docx,txt,md,csv,json,xml,html,py,js,ts,java,cpp,go,rs,rb,php

# ===================================
# Cache Configuration
# ===================================
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true

# ===================================
# Background Jobs
# ===================================
ENABLE_BACKGROUND_JOBS=true
JOB_QUEUE_NAME=synapse_jobs