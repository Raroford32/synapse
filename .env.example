# ===================================
# Synapse Configuration
# ===================================
# Copy this file to .env and update with your values

# Environment (development, staging, production)
ENVIRONMENT=development

# ===================================
# Security
# ===================================
# Generate strong secrets for production!
# You can generate these with: openssl rand -hex 32
API_KEY=your-synapse-api-key-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production

# ===================================
# Database Configuration
# ===================================
# PostgreSQL with pgvector extension
DATABASE_URL=postgresql://synapse:synapse_password@localhost:5432/synapse_db

# Redis for caching (optional but recommended)
REDIS_URL=redis://localhost:6379

# ===================================
# OpenRouter Configuration (Primary LLM Provider)
# ===================================
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# OpenRouter Base URL (usually doesn't need to be changed)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Your app name (shows in OpenRouter dashboard)
OPENROUTER_APP_NAME=Synapse

# Your site URL (optional, for OpenRouter analytics)
OPENROUTER_SITE_URL=http://localhost:8000

# ===================================
# OpenAI Configuration (For Embeddings Only)
# ===================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI Embedding Model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===================================
# Model Selection via OpenRouter
# ===================================
# OpenRouter provides access to multiple models
# Examples: 
# - openai/gpt-4-turbo-preview
# - anthropic/claude-3-opus
# - anthropic/claude-3-5-sonnet
# - google/gemini-pro
# - meta-llama/llama-3-70b-instruct
# - mistralai/mixtral-8x7b-instruct

# Default models for different use cases (via OpenRouter)
DEFAULT_MODEL=openai/gpt-4o-mini
SMART_MODEL=anthropic/claude-3-5-sonnet
FAST_MODEL=meta-llama/llama-3-8b-instruct
CODE_MODEL=anthropic/claude-3-5-sonnet

# Model selection strategy
MODEL_SELECTION_STRATEGY=auto  # auto, manual, cost-optimized, performance

# ===================================
# Local Model Configuration (Optional)
# ===================================
# Ollama for local models (optional fallback)
OLLAMA_HOST=http://localhost:11434
USE_LOCAL_MODELS=false

# ===================================
# Memory System Configuration
# ===================================
# Mem0 configuration
MEM0_CONFIG_PATH=/app/config/mem0.yaml
MEM0_VECTOR_STORE=pgvector

# ===================================
# RAG System Configuration  
# ===================================
# R2R configuration
R2R_CONFIG_PATH=/app/config/r2r.yaml
R2R_VECTOR_DIMENSION=1536
R2R_CHUNK_SIZE=512
R2R_CHUNK_OVERLAP=50

# ===================================
# MCP (Model Context Protocol)
# ===================================
# MCP server configuration
MCP_ENABLED=true
MCP_SERVER_PORT=8001

# ===================================
# CORS Settings
# ===================================
# Comma-separated list of allowed origins
# Use * for all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,*

# ===================================
# Logging
# ===================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===================================
# Optional Services
# ===================================
# Sentry for error tracking (optional)
SENTRY_DSN=

# Prometheus metrics (optional)
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=9090

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===================================
# WebSocket Configuration
# ===================================
WS_HEARTBEAT_INTERVAL=30
WS_CONNECTION_TIMEOUT=600

# ===================================
# File Upload Configuration
# ===================================
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_EXTENSIONS=pdf,docx,txt,md,csv,json,xml,html,py,js,ts,java,cpp,go,rs,rb,php

# ===================================
# Cache Configuration
# ===================================
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true

# ===================================
# Background Jobs
# ===================================
ENABLE_BACKGROUND_JOBS=true
JOB_QUEUE_NAME=synapse_jobs